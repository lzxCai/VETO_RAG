  <data key="d6"></data>
</node>
<node id="Statutory Holiday">
  <data key="d0">Statutory Holiday</data>
  <data key="d1">event</data>
  <data key="d2">A statutory holiday is a legally mandated day off for workers, established by national laws and regulations.&lt;SEP&gt;A statutory holiday is a legally mandated day off, during which employers must pay wages to laborers.</data>
  <data key="d3">chunk-9ade40507636905dbb256fde347d4c4d&lt;SEP&gt;chunk-29625ec97f3aa262c09d4aa1c862291b</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320768</data>
  <data key="d6"></data>
</node>
<node id="Article 40">
  <data key="d0">Article 40</data>
  <data key="d1">content</data>
  <data key="d2">Article 40 is a provision in China's Labor Law specifying statutory holidays during which employers must arrange worker leave.</data>
  <data key="d3">chunk-9ade40507636905dbb256fde347d4c4d</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320665</data>
  <data key="d6"></data>
