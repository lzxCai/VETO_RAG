  <data key="d12">1773321256</data>
  <data key="d13"></data>
</edge>
<edge source="Employer" target="Article Thirty-One">
  <data key="d7">1.0</data>
  <data key="d8">Article Thirty-One imposes a legal duty on employers to accept and process the laborer's written termination notice after the thirty-day period.</data>
  <data key="d9">legal obligation,regulatory compliance</data>
  <data key="d10">chunk-82eedbfc6978ce7b8284768afbfab33f</data>
  <data key="d11">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d12">1773320516</data>
  <data key="d13"></data>
</edge>
