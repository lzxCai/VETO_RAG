<node id="Spring Festival">
  <data key="d0">Spring Festival</data>
  <data key="d1">event</data>
  <data key="d2">The Spring Festival is a major traditional Chinese holiday and a statutory holiday requiring employers to arrange worker leave.</data>
  <data key="d3">chunk-9ade40507636905dbb256fde347d4c4d</data>
