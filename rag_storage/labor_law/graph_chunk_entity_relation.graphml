  <data key="d13"></data>
</edge>
<edge source="Employer" target="Article 48">
  <data key="d7">1.0</data>
  <data key="d8">Article 48 imposes a binding legal obligation on Employers to pay wages no lower than the local minimum wage standard.</data>
  <data key="d9">legal obligation,regulatory compliance</data>
