<edge source="Employer" target="Rest Day Work">
  <data key="d7">1.0</data>
  <data key="d8">The Employer is legally required to pay at least 200% of normal wages for Rest Day Work when no compensatory leave is provided.</data>
  <data key="d9">legal obligation,wage payment</data>
  <data key="d10">chunk-eb26be1be6719b2d63eda122721b5d68</data>
  <data key="d11">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d12">1773320392</data>
  <data key="d13"></data>
</edge>
<edge source="Employer" target="Statutory Holiday Work">
  <data key="d7">1.0</data>
  <data key="d8">The Employer is legally required to pay at least 300% of normal wages for Statutory Holiday Work.</data>
  <data key="d9">legal obligation,wage payment</data>
  <data key="d10">chunk-eb26be1be6719b2d63eda122721b5d68</data>
  <data key="d11">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
