  <data key="d0">International Labor Day</data>
  <data key="d1">event</data>
  <data key="d2">International Labor Day, observed on May 1st, is a statutory holiday in China mandating worker rest.</data>
  <data key="d3">chunk-9ade40507636905dbb256fde347d4c4d</data>
