  <data key="d0">Favoritism and Malpractice</data>
  <data key="d1">concept</data>
  <data key="d2">Favoritism and Malpractice refers to misconduct involving biased or corrupt behavior for personal or others' benefit.</data>
  <data key="d3">chunk-534cee49a6033035c2c5393b14d42b64</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320998</data>
  <data key="d6"></data>
</node>
<node id="Article 103">
  <data key="d0">Article 103</data>
  <data key="d1">content</data>
  <data key="d2">Article 103 is a provision in Chinese labor law specifying legal consequences for misconduct by labor administration staff.</data>
  <data key="d3">chunk-534cee49a6033035c2c5393b14d42b64</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320998</data>
  <data key="d6"></data>
</node>
<node id="Labor Regulations">
  <data key="d0">Labor Regulations</data>
  <data key="d1">content</data>
  <data key="d2">Labor regulations are internal rules established by employers that must comply with legal and regulatory requirements.</data>
  <data key="d3">chunk-5a7d21f4dbacb9974d96f6a4b7cd73aa</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320999</data>
  <data key="d6"></data>
</node>
<node id="Article 89">
  <data key="d0">Article 89</data>
  <data key="d1">content</data>
  <data key="d2">Article 89 specifies administrative penalties-including warnings and corrective orders-for employers whose labor regulations violate laws or regulations, and mandates compensation liability if workers suffer damage.</data>
  <data key="d3">chunk-5a7d21f4dbacb9974d96f6a4b7cd73aa</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320999</data>
  <data key="d6"></data>
</node>
<node id="Article 90">
  <data key="d0">Article 90</data>
  <data key="d1">content</data>
  <data key="d2">Article 90 prescribes administrative measures-including warnings, corrective orders, and possible fines-against employers who unlawfully extend working hours.</data>
  <data key="d3">chunk-5a7d21f4dbacb9974d96f6a4b7cd73aa</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320999</data>
  <data key="d6"></data>
</node>
<node id="Article 91">
  <data key="d0">Article 91</data>
  <data key="d1">content</data>
  <data key="d2">Article 91 enumerates specific violations such as wage withholding or unjustified delay, and requires the Labor Administrative Department to order payment of wages, economic compensation, and potentially additional damages.</data>
  <data key="d3">chunk-5a7d21f4dbacb9974d96f6a4b7cd73aa</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320999</data>
  <data key="d6"></data>
</node>
<node id="Compensation Payment">
  <data key="d0">Compensation Payment</data>
  <data key="d1">concept</data>
  <data key="d2">Compensation payment refers to the employer’s obligation-enforceable by the Labor Administrative Department-to pay damages to workers harmed by unlawful acts.</data>
  <data key="d3">chunk-5a7d21f4dbacb9974d96f6a4b7cd73aa</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320999</data>
  <data key="d6"></data>
