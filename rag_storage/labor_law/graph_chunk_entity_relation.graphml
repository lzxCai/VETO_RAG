</node>
<node id="Social Insurance Payment">
  <data key="d0">Social Insurance Payment</data>
  <data key="d1">concept</data>
  <data key="d2">Social insurance payment refers to the mandatory, timely, and full disbursement of social insurance funds to eligible laborers.</data>
