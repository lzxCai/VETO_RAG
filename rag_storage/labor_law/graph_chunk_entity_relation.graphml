  <data key="d5">1773320665</data>
  <data key="d6"></data>
</node>
<node id="National Day">
  <data key="d0">National Day</data>
  <data key="d1">event</data>
  <data key="d2">National Day of the People's Republic of China, celebrated on October 1st, is a statutory holiday requiring employer-provided leave.</data>
  <data key="d3">chunk-9ade40507636905dbb256fde347d4c4d</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
