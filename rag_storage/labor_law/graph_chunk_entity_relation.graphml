  <data key="d0">Article One Hundred</data>
  <data key="d1">content</data>
  <data key="d2">Article One Hundred is a provision in Chinese labor law specifying penalties for employers who fail to pay social insurance premiums without justification.</data>
  <data key="d3">chunk-1c3f29bba2e48ace661e0e106cd6c106</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320673</data>
  <data key="d6"></data>
