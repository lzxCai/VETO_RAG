</node>
<node id="Public Facilities">
  <data key="d0">Public Facilities</data>
  <data key="d1">artifact</data>
  <data key="d2">Public facilities are infrastructure assets whose failure may impact public interests and necessitate urgent repair under Article 42.</data>
  <data key="d3">chunk-5144d09ac2f1a1e98af0cc571325d656</data>
  <data key="d4">/Users/pysama/first_prize_RAG/dataset/labor_law.md</data>
  <data key="d5">1773320556</data>
  <data key="d6"></data>
</node>
<node id="Transportation Lines">
  <data key="d0">Transportation Lines</data>
  <data key="d1">artifact</data>
  <data key="d2">Transportation lines are critical infrastructure whose failure affects public interests and triggers the exception for extended working hours under Article 42.</data>
