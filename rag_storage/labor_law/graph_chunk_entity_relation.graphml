  <data key="d13"></data>
</edge>
<edge source="Employer" target="Forced Labor">
  <data key="d7">1.0</data>
  <data key="d8">The Employer is prohibited from engaging in Forced Labor using violence, threats, or illegal restriction of personal freedom.</data>
  <data key="d9">legal violation,prohibited conduct</data>
