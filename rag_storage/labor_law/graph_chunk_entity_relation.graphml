<edge source="Employer" target="Illegal Restriction of Personal Freedom">
  <data key="d7">1.0</data>
  <data key="d8">The Employer is prohibited from using Illegal Restriction of Personal Freedom as a means to force labor under Article 96.</data>
  <data key="d9">coercion method,prohibited conduct</data>
